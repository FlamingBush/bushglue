digraph bushglue {
    graph [
        rankdir=TD
        fontname="Helvetica"
        fontsize=12
        nodesep=0.6
        ranksep=0.8
        bgcolor="white"
    ]
    node [
        fontname="Helvetica"
        fontsize=11
        shape=box
        style="rounded,filled"
        fillcolor="#f5f5f5"
        color="#555555"
        margin="0.15,0.1"
    ]
    edge [
        fontname="Helvetica"
        fontsize=9
        color="#444444"
        labeldistance=2
    ]

    // IO
    MIC [label="Microphone\n(audio input)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    SPEAKER [label="Speaker\n(audio output)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    FLAME [label="Solenoids\n(propane output)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    BUTTONS [label="Buttons\n(electrical input)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    FIRECONTROL [label="FireControl\n(website input)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    //MONITOR [label="bush-monitor\n(terminal input)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]

    // Services
    STT [label="bush-stt\nstt-service.py\n──────────────\nVosk STT\nmic input" fillcolor="#cfe2f3" color="#1155cc"]
    T2V [label="bush-t2v\nt2v-service.py\n──────────────\nRust HTTP :8765\nOllama embed\nChromaDB :8000" fillcolor="#cfe2f3" color="#1155cc"]
    TTS [label="bush-tts\ntts-service.py\n──────────────\nespeak-ng\nsox reverb" fillcolor="#cfe2f3" color="#1155cc"]
    SENTIMENT [label="bush-sentiment\nsentiment-service.py\n──────────────\nDistilBERT\nsentiment analysis\nfire orchestration" fillcolor="#cfe2f3" color="#1155cc"]
    RELAYS [label="relay-control/\nCIRCUITPY/code.py\n──────────────\nrpi pico 2\nlives in orange box" fillcolor="#cfe2f3" color="#1155cc"]
    FLAME_EXPR [label="bush-flame-expression\n──────────────\nsentiment → valve\nspeech modulation\n10 Hz target" fillcolor="#cfe2f3" color="#1155cc"]
    NEEDLE_VALVE [label="Needle Valve\n(propane modulation)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]

    // Layout hints
    { rank=source; MIC; BUTTONS; FIRECONTROL }
    { rank=same; TTS; SENTIMENT; FLAME_EXPR }
    { rank=sink; SPEAKER; FLAME; NEEDLE_VALVE }

    // Audio paths
    MIC -> STT [color="#38761d"]
    TTS -> SPEAKER [color="#38761d"]

    // Main pipeline
    STT -> T2V [label="bush/pipeline/stt/transcript" color="#1155cc"]
    T2V -> TTS [label="bush/pipeline/t2v/verse" color="#1155cc"]
    T2V -> SENTIMENT [label="bush/pipeline/t2v/verse" color="#1155cc"]

    // TTS feedback
    TTS -> STT [label="bush/pipeline/tts/speaking\nbush/pipeline/tts/done" color="#1155cc"]
    TTS -> SENTIMENT [label="bush/pipeline/tts/done" color="#1155cc"]

    // Flame effects (solenoid pulsing)
    SENTIMENT -> RELAYS [label="bush/flame/pulse" color="#1155cc"]
    FIRECONTROL -> RELAYS [label="bush/flame/pulse" color="#1155cc"]
    BUTTONS -> FLAME [color="#38761d"]
    RELAYS -> FLAME [color="#38761d"]

    // Needle valve (smooth modulation)
    SENTIMENT -> FLAME_EXPR [label="bush/pipeline/\nsentiment/result" color="#1155cc"]
    TTS -> FLAME_EXPR [label="bush/pipeline/tts/\nspeaking, done" color="#1155cc"]
    FLAME_EXPR -> RELAYS [label="bush/fire/valve/target" color="#1155cc"]
    RELAYS -> NEEDLE_VALVE [color="#38761d"]
}

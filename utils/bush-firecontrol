#!/usr/bin/env python3
"""
bush-firecontrol — MQTT flame controller TUI
Usage: bush-firecontrol [--broker HOST] [--port PORT]

QWERTY layout philosophy:
  LEFT half  → BIGJET  (big, sustained, powerful)
  RIGHT half → FLARE   (sharp, short, precise)

Key rows map to pulse durations — top row = shortest, bottom row = longest.
Within each half the keys are ordered left→right = shorter→longer.
"""

import argparse
import curses
import json
import subprocess
import time
import threading
import collections
import paho.mqtt.client as mqtt

TOPIC_FLAME  = "bush/flame/pulse"

BIGJET_COLOR = 1
FLARE_COLOR  = 2

KEY_MAP = {
    # ── TOP ROW — short pulses ───────────────────────────────────────────────
    ord('q'): ("bigjet",  50,   "Q",  "50ms",  BIGJET_COLOR),
    ord('w'): ("bigjet",  100,  "W",  "100ms", BIGJET_COLOR),
    ord('e'): ("bigjet",  150,  "E",  "150ms", BIGJET_COLOR),
    ord('r'): ("bigjet",  200,  "R",  "200ms", BIGJET_COLOR),
    ord('t'): ("bigjet",  300,  "T",  "300ms", BIGJET_COLOR),
    ord('y'): ("flare",   50,   "Y",  "50ms",  FLARE_COLOR),
    ord('u'): ("flare",   100,  "U",  "100ms", FLARE_COLOR),
    ord('i'): ("flare",   150,  "I",  "150ms", FLARE_COLOR),
    ord('o'): ("flare",   200,  "O",  "200ms", FLARE_COLOR),
    ord('p'): ("flare",   300,  "P",  "300ms", FLARE_COLOR),

    # ── HOME ROW — medium pulses ─────────────────────────────────────────────
    ord('a'): ("bigjet",  400,  "A",  "400ms", BIGJET_COLOR),
    ord('s'): ("bigjet",  600,  "S",  "600ms", BIGJET_COLOR),
    ord('d'): ("bigjet",  800,  "D",  "800ms", BIGJET_COLOR),
    ord('f'): ("bigjet",  1000, "F",  "1.0s",  BIGJET_COLOR),
    ord('g'): ("bigjet",  1500, "G",  "1.5s",  BIGJET_COLOR),
    ord('h'): ("flare",   400,  "H",  "400ms", FLARE_COLOR),
    ord('j'): ("flare",   600,  "J",  "600ms", FLARE_COLOR),
    ord('k'): ("flare",   800,  "K",  "800ms", FLARE_COLOR),
    ord('l'): ("flare",   1000, "L",  "1.0s",  FLARE_COLOR),
    ord(';'): ("flare",   1500, ";",  "1.5s",  FLARE_COLOR),

    # ── BOTTOM ROW — long pulses ─────────────────────────────────────────────
    ord('z'): ("bigjet",  2000, "Z",  "2.0s",  BIGJET_COLOR),
    ord('x'): ("bigjet",  3000, "X",  "3.0s",  BIGJET_COLOR),
    ord('c'): ("bigjet",  4000, "C",  "4.0s",  BIGJET_COLOR),
    ord('v'): ("bigjet",  5000, "V",  "5.0s",  BIGJET_COLOR),
    ord('b'): ("bigjet",  8000, "B",  "8.0s",  BIGJET_COLOR),
    ord('n'): ("flare",   2000, "N",  "2.0s",  FLARE_COLOR),
    ord('m'): ("flare",   3000, "M",  "3.0s",  FLARE_COLOR),
    ord(','): ("flare",   4000, ",",  "4.0s",  FLARE_COLOR),
    ord('.'): ("flare",   5000, ".",  "5.0s",  FLARE_COLOR),
    ord('/'): ("flare",   8000, "/",  "8.0s",  FLARE_COLOR),
}

ROWS = [
    list("qwertyuiop"),
    list("asdfghjkl;"),
    list("zxcvbnm,./"),
]
ROW_LABELS = ["SHORT", "MEDIUM", "LONG"]

MAX_LOG     = 40
log_entries = collections.deque(maxlen=MAX_LOG)
log_lock    = threading.Lock()

active = {
    "flare":  {"until": 0.0, "duration": 0, "key": ""},
    "bigjet": {"until": 0.0, "duration": 0, "key": ""},
}
active_lock = threading.Lock()

mqtt_status = {"connected": False, "msg": "Connecting…"}


def on_connect(client, userdata, flags, rc, props=None):
    if rc == 0:
        mqtt_status["connected"] = True
        broker, port = userdata
        mqtt_status["msg"] = f"Connected  {broker}:{port}"
    else:
        mqtt_status["connected"] = False
        mqtt_status["msg"] = f"MQTT error rc={rc}"


def on_disconnect(client, userdata, rc, props=None, *args):
    mqtt_status["connected"] = False
    mqtt_status["msg"] = "Disconnected — reconnecting…"


def fire(mq, valve, duration_ms, key_label):
    if not mqtt_status["connected"]:
        with log_lock:
            log_entries.appendleft((time.time(), key_label, valve, duration_ms, False))
        return
    mq.publish(TOPIC_FLAME, json.dumps({"valve": valve, "ms": duration_ms}), qos=0)
    now = time.time()
    with active_lock:
        active[valve]["until"]    = now + duration_ms / 1000.0
        active[valve]["duration"] = duration_ms
        active[valve]["key"]      = key_label
    with log_lock:
        log_entries.appendleft((now, key_label, valve, duration_ms, True))


def safe_addstr(win, y, x, text, attr=0):
    h, w = win.getmaxyx()
    if y < 0 or y >= h or x < 0:
        return
    if x + len(text) > w:
        text = text[:w - x]
    try:
        win.addstr(y, x, text, attr)
    except curses.error:
        pass


def draw_bar(win, y, x, width, fraction, color_pair):
    filled  = max(0, min(width, int(width * fraction)))
    bar_on  = "█" * filled
    bar_off = "░" * (width - filled)
    safe_addstr(win, y, x,          bar_on,  curses.color_pair(color_pair) | curses.A_BOLD)
    safe_addstr(win, y, x + filled, bar_off, curses.color_pair(5))


def tui(stdscr, mq):
    curses.curs_set(0)
    stdscr.nodelay(True)
    stdscr.timeout(33)

    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_CYAN,  -1)
    curses.init_pair(2, curses.COLOR_RED,   -1)
    curses.init_pair(3, 8,                  -1)
    curses.init_pair(4, curses.COLOR_WHITE, -1)
    curses.init_pair(5, curses.COLOR_BLACK, curses.COLOR_BLACK)
    curses.init_pair(6, curses.COLOR_YELLOW, -1)
    curses.init_pair(7, curses.COLOR_GREEN, -1)
    curses.init_pair(8, curses.COLOR_RED,   -1)

    C_BIGJET = curses.color_pair(1) | curses.A_BOLD
    C_FLARE  = curses.color_pair(2) | curses.A_BOLD
    C_DIM    = curses.color_pair(3)
    C_WHITE  = curses.color_pair(4) | curses.A_BOLD
    C_ACCENT = curses.color_pair(6) | curses.A_BOLD
    C_OK     = curses.color_pair(7)
    C_ERR    = curses.color_pair(8) | curses.A_BOLD

    while True:
        h, w = stdscr.getmaxyx()
        stdscr.erase()
        now = time.time()

        # Title bar
        title = " 🔥 FIRE CONTROL  "
        safe_addstr(stdscr, 0, 0, "─" * w, C_DIM)
        safe_addstr(stdscr, 0, max(0, (w - len(title)) // 2), title, C_WHITE)
        conn_text  = f" ● {mqtt_status['msg']} "
        conn_color = C_OK if mqtt_status["connected"] else C_ERR
        safe_addstr(stdscr, 0, w - len(conn_text) - 1, conn_text, conn_color)

        # Section headers
        mid = w // 2
        safe_addstr(stdscr, 2, 2,       "〓  B I G J E T  〓", C_BIGJET)
        safe_addstr(stdscr, 2, mid + 2, "〓  F L A R E  〓",   C_FLARE)
        safe_addstr(stdscr, 3, 0, "─" * w, C_DIM)

        # Keyboard grid
        CELL, ROW_START_Y, INDENT = 9, 4, [1, 2, 3]
        for row_i, row_keys in enumerate(ROWS):
            y      = ROW_START_Y + row_i * 3
            indent = INDENT[row_i]
            safe_addstr(stdscr, y, 0, f"{ROW_LABELS[row_i]:>6}", C_DIM)
            for col_i, ch in enumerate(row_keys):
                x    = 7 + indent + col_i * CELL
                info = KEY_MAP.get(ord(ch))
                if info is None:
                    continue
                valve, dur, key_lbl, dur_lbl, side = info
                color = C_BIGJET if side == BIGJET_COLOR else C_FLARE
                with active_lock:
                    a         = active[valve]
                    is_active = (a["until"] - now) > 0 and a["key"] == key_lbl
                box_attr = color | curses.A_REVERSE if is_active else color
                safe_addstr(stdscr, y,     x, f"┌─{key_lbl:^3}─┐", box_attr)
                safe_addstr(stdscr, y + 1, x, f"│{dur_lbl:^7}│",   box_attr)
                safe_addstr(stdscr, y + 2, x, f"└───────┘",        box_attr)
            safe_addstr(stdscr, y,     mid, "│", C_DIM)
            safe_addstr(stdscr, y + 1, mid, "│", C_DIM)
            safe_addstr(stdscr, y + 2, mid, "│", C_DIM)

        # Pulse bars
        bar_y = ROW_START_Y + len(ROWS) * 3 + 1
        safe_addstr(stdscr, bar_y, 0, "─" * w, C_DIM)
        bar_y += 1
        bar_w  = mid - 6
        for label, valve, color, cx in [
            ("BIGJET", "bigjet", 1, 1),
            ("FLARE",  "flare",  2, mid + 1),
        ]:
            with active_lock:
                a         = active[valve]
                remaining = max(0.0, a["until"] - now)
                dur       = a["duration"]
                frac      = (remaining / (dur / 1000.0)) if dur > 0 else 0.0
            ca = curses.color_pair(color) | curses.A_BOLD
            safe_addstr(stdscr, bar_y,     cx, label, ca)
            safe_addstr(stdscr, bar_y + 1, cx, f"{'FIRING' if frac > 0 else 'IDLE':^6}", ca)
            bx, bw = cx + 7, bar_w - 8
            draw_bar(stdscr, bar_y + 1, bx, bw, frac, color)
            if frac > 0:
                safe_addstr(stdscr, bar_y + 1, bx + bw + 1,
                             f"{int(remaining * 1000):>5}ms", ca)

        # Event log
        log_y = bar_y + 3
        safe_addstr(stdscr, log_y, 0, "─" * w, C_DIM)
        log_y += 1
        safe_addstr(stdscr, log_y, 1, "EVENT LOG", C_ACCENT)
        log_y += 1
        with log_lock:
            entries = list(log_entries)
        for i, (ts, key, valve, dur, ok) in enumerate(entries[:h - log_y - 2]):
            is_flare = valve == "flare"
            line = f"  {time.strftime('%H:%M:%S', time.localtime(ts))}  [{key}]  "
            safe_addstr(stdscr, log_y + i, 0, line, C_DIM)
            xo = len(line)
            safe_addstr(stdscr, log_y + i, xo, ("✓" if ok else "✗") + " ",
                         C_OK if ok else C_ERR)
            safe_addstr(stdscr, log_y + i, xo + 2,
                         f"{'FLARE ' if is_flare else 'BIGJET'} {dur}ms",
                         C_FLARE if is_flare else C_BIGJET)

        # Footer
        footer = " Q/W/E/R/T  A/S/D/F/G  Z/X/C/V/B → BIGJET   Y/U/I/O/P  H/J/K/L/;  N/M/,./  → FLARE    ESC quit "
        safe_addstr(stdscr, h - 1, 0, "─" * w, C_DIM)
        safe_addstr(stdscr, h - 1, max(0, (w - len(footer)) // 2), footer, C_DIM)

        stdscr.refresh()

        ch = stdscr.getch()
        if ch == 27:
            break
        if ch in KEY_MAP:
            valve, dur, key_lbl, *_ = KEY_MAP[ch]
            fire(mq, valve, dur, key_lbl)

    mq.disconnect()


def _windows_host_ip() -> str:
    result = subprocess.run(["ip", "route", "show"], capture_output=True, text=True)
    for line in result.stdout.splitlines():
        if line.startswith("default"):
            return line.split()[2]
    return "localhost"


def main():
    parser = argparse.ArgumentParser(description="Flame controller TUI")
    parser.add_argument("--broker", default=_windows_host_ip())
    parser.add_argument("--port",   type=int, default=1883)
    args = parser.parse_args()

    mq = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2, userdata=(args.broker, args.port))
    mq.on_connect    = on_connect
    mq.on_disconnect = on_disconnect

    def _thread():
        try:
            mq.connect(args.broker, args.port, keepalive=10)
        except Exception as e:
            mqtt_status["msg"] = f"Connect failed: {e}"
        mq.loop_forever()

    threading.Thread(target=_thread, daemon=True).start()
    curses.wrapper(tui, mq)


if __name__ == "__main__":
    main()

#!/usr/bin/env python3
"""
Synthesize a phrase to WAV (or use an existing WAV) and inject it into the
Bush pipeline by playing it into the ALSA loopback device that stt-service.py
is capturing from.

Generated WAVs are saved to WAVS_DIR (default: ~/wavs/) for future replay.

Usage:
    bush-pray --phrase "what is the meaning of fire"
    bush-pray --file ~/wavs/what_is_the_meaning_of_fire.wav

Environment:
    WAVS_DIR        where to save generated WAVs  (default: ~/wavs)
    LOOPBACK_DEVICE ALSA playback device to write into  (default: hw:3,0)
"""
import argparse
import os
import re
import subprocess
import sys
from pathlib import Path

WAVS_DIR = Path(os.environ.get("WAVS_DIR", Path.home() / "wavs"))
LOOPBACK_DEVICE = os.environ.get("LOOPBACK_DEVICE", "hw:Loopback,0")


def phrase_to_filename(phrase: str) -> str:
    slug = re.sub(r"[^a-z0-9]+", "_", phrase.lower().strip()).strip("_")
    return f"{slug}.wav"


def synthesize(phrase: str, out_path: Path) -> None:
    espeak = subprocess.Popen(
        ["espeak-ng", "-v", "en-us", "-s", "130", "--stdout", phrase],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )
    subprocess.run(
        ["sox", "-t", "wav", "-", "-r", "16000", "-c", "1", "-b", "16", str(out_path)],
        stdin=espeak.stdout,
        check=True,
    )
    espeak.stdout.close()
    espeak.wait()


def main():
    parser = argparse.ArgumentParser(
        description="Synthesize or load a WAV and play it into the loopback mic device."
    )
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument("--phrase", help="Text to synthesize and inject")
    group.add_argument("--file", help="Path to existing WAV file")
    args = parser.parse_args()

    if args.phrase:
        WAVS_DIR.mkdir(parents=True, exist_ok=True)
        wav = WAVS_DIR / phrase_to_filename(args.phrase)
        if not wav.exists():
            print(f"[bush-pray] Synthesizing → {wav}")
            synthesize(args.phrase, wav)
        else:
            print(f"[bush-pray] Using cached  → {wav}")
    else:
        wav = Path(args.file).expanduser()
        if not wav.exists():
            print(f"[bush-pray] File not found: {wav}", file=sys.stderr)
            sys.exit(1)

    print(f"[bush-pray] Playing into {LOOPBACK_DEVICE}")
    subprocess.run(
        ["sox", str(wav), "-t", "alsa", LOOPBACK_DEVICE],
        check=True,
    )


if __name__ == "__main__":
    main()

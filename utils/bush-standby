#!/bin/bash
# bush-standby: stop the pipeline and loop standby audio.
# Stops all bush pipeline services, leaves mosquitto running.
# Plays ~/wavs/standby.mp3 on loop until interrupted (Ctrl-C or SIGTERM).
#
# Usage:
#   bush-standby              # enter standby, persist state
#   bush-standby --undo       # restore services that were running before standby
#   bush-standby --device hw:0  # override output device (default: hw:0)

DEVICE="plughw:CODEC"
UNDO=0
STATE_FILE="/tmp/bush-standby.state"
STANDBY_FILE="${BUSH_STANDBY_FILE:-/home/odroid/standby.mp3}"
# Resolve script dir even when called by name through PATH
SCRIPT_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"

SERVICES=(
    bush-stt
    bush-tts
    bush-t2v
    bush-sentiment
    bush-audio-agent
    bush-discord
)

for arg in "$@"; do
    case "$arg" in
        --undo) UNDO=1 ;;
        --device) shift; DEVICE="$1" ;;
        --device=*) DEVICE="${arg#--device=}" ;;
    esac
done

if [[ $UNDO -eq 1 ]]; then
    if [[ ! -f "$STATE_FILE" ]]; then
        echo "bush-standby: no saved state at $STATE_FILE" >&2
        exit 1
    fi
    echo "bush-standby: restoring services..."
    systemctl stop bush-firecontrol-web 2>/dev/null
    while IFS= read -r svc; do
        systemctl start "$svc"
        echo "  started $svc"
    done < "$STATE_FILE"
    rm -f "$STATE_FILE"
    echo "bush-standby: done"
    exit 0
fi

if [[ ! -f "$STANDBY_FILE" ]]; then
    echo "bush-standby: $STANDBY_FILE not found"
    echo "bush-standby: set BUSH_STANDBY_FILE=<path> or place a file at $STANDBY_FILE"
    exit 1
fi

# Save which services are currently running, then stop them
rm -f "$STATE_FILE"
echo "bush-standby: stopping pipeline services..."
for svc in "${SERVICES[@]}"; do
    if systemctl is-active --quiet "$svc" 2>/dev/null; then
        systemctl stop "$svc"
        echo "$svc" >> "$STATE_FILE"
        echo "  stopped $svc"
    fi
done

WEB_PORT=8080

cleanup() {
    echo "bush-standby: stopping"
    systemctl stop bush-firecontrol-web 2>/dev/null
    kill "$SOX_PID" 2>/dev/null
    wait "$SOX_PID" 2>/dev/null
    exit 0
}
trap cleanup SIGTERM SIGINT

# Start web fire control service
systemctl start bush-firecontrol-web
LOCAL_IP=$(ip -4 addr show scope global | awk '/inet/{print $2}' | cut -d/ -f1 | head -1)
echo "bush-standby: fire control → http://${LOCAL_IP:-<odroid-ip>}:${WEB_PORT}/"

echo "bush-standby: looping $STANDBY_FILE on $DEVICE  (Ctrl-C or --undo to restore)"

# Wait for the ALSA card to appear, then do a software USB reset.
# A physical replug is needed to reliably open the PCM2912A on the RK3568
# OHCI controller after boot — this mimics it without touching the hardware.
# Do NOT open the device to test it before the real open: any prior open/close
# corrupts the codec's rate state.
wait_for_device() {
    local card="${DEVICE#*:}"   # CODEC from plughw:CODEC
    card="${card%%,*}"
    while [[ ! -e "/proc/asound/$card" ]]; do
        echo "bush-standby: waiting for /proc/asound/$card ..."
        sleep 3
    done
    # Find the USB sysfs path for idVendor=08bb (TI PCM2912A)
    local usb_dev
    usb_dev=$(grep -rl "08bb" /sys/bus/usb/devices/*/idVendor 2>/dev/null | head -1)
    usb_dev="${usb_dev%/idVendor}"
    if [[ -n "$usb_dev" && -w "$usb_dev/authorized" ]]; then
        echo "bush-standby: software USB reset of $(basename "$usb_dev")..."
        echo 0 > "$usb_dev/authorized"
        sleep 2
        echo 1 > "$usb_dev/authorized"
        # Wait for the card to reappear after re-enumeration
        while [[ ! -e "/proc/asound/$card" ]]; do sleep 1; done
        echo "bush-standby: re-enumerated, settling 8s..."
        sleep 8
    else
        echo "bush-standby: USB device not found, settling 12s..."
        sleep 12
    fi
}

wait_for_device
while true; do
    sox "$STANDBY_FILE" -t alsa "$DEVICE" 2>/dev/null &
    SOX_PID=$!
    wait "$SOX_PID"
    # Brief pause on failure to avoid hammering a broken device
    [[ $? -ne 0 ]] && sleep 5
done

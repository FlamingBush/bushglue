#!/usr/bin/env python3
"""
bush-valve — CLI for needle valve control via MQTT

Usage:
    bush-valve target 0.5       Set valve to 50% open
    bush-valve home             Trigger homing sequence
    bush-valve stop             Emergency stop
    bush-valve status           Print current valve status (waits for one message)
    bush-valve calibrate 16000  Set open_steps calibration
    bush-valve watch            Stream valve position updates

Requires mosquitto or paho-mqtt. Uses the same broker auto-detection as other bush services.
"""
import os, sys
_venv = os.path.abspath(os.path.join(os.path.dirname(os.path.abspath(__file__)), os.pardir, ".venv"))
if os.path.isdir(_venv) and sys.prefix != _venv:
    os.execv(os.path.join(_venv, "bin", "python"), [os.path.join(_venv, "bin", "python")] + sys.argv)

import json
import threading
import time

import paho.mqtt.client as mqtt

MQTT_PORT = 1883

TOPIC_TARGET    = "bush/fire/valve/target"
TOPIC_HOME      = "bush/fire/valve/home"
TOPIC_STOP      = "bush/fire/valve/stop"
TOPIC_CALIBRATE = "bush/fire/valve/calibrate"
TOPIC_STATUS    = "bush/fire/valve/status"
TOPIC_ACTUAL    = "bush/fire/valve/actual"


def get_broker():
    try:
        from bushutil import get_mqtt_broker
        return get_mqtt_broker()
    except Exception:
        return "localhost"


def publish_and_exit(broker, topic, payload=""):
    c = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)
    c.connect(broker, MQTT_PORT, 10)
    c.publish(topic, payload)
    c.disconnect()


def subscribe_one(broker, topic, timeout=5.0):
    result = [None]
    got = threading.Event()

    def on_connect(client, userdata, flags, rc, properties=None):
        client.subscribe(topic)

    def on_message(client, userdata, msg):
        result[0] = msg.payload.decode(errors="replace")
        got.set()

    c = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)
    c.on_connect = on_connect
    c.on_message = on_message
    c.connect(broker, MQTT_PORT, 10)
    c.loop_start()
    got.wait(timeout=timeout)
    c.loop_stop()
    c.disconnect()
    return result[0]


def watch(broker, topics):
    def on_connect(client, userdata, flags, rc, properties=None):
        for t in topics:
            client.subscribe(t)
        print(f"Watching {', '.join(topics)}  (Ctrl+C to stop)")

    def on_message(client, userdata, msg):
        ts = time.strftime("%H:%M:%S")
        print(f"  {ts}  {msg.topic}  {msg.payload.decode(errors='replace')}")

    c = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)
    c.on_connect = on_connect
    c.on_message = on_message
    c.connect(broker, MQTT_PORT, 10)
    try:
        c.loop_forever()
    except KeyboardInterrupt:
        print()
        c.disconnect()


def main():
    if len(sys.argv) < 2:
        print(__doc__.strip())
        sys.exit(1)

    cmd = sys.argv[1]
    broker = get_broker()

    if cmd == "target":
        if len(sys.argv) < 3:
            print("Usage: bush-valve target <0.0-1.0>")
            sys.exit(1)
        val = float(sys.argv[2])
        publish_and_exit(broker, TOPIC_TARGET, f"{val:.3f}")
        print(f"target -> {val:.3f}")

    elif cmd == "home":
        publish_and_exit(broker, TOPIC_HOME)
        print("homing...")

    elif cmd == "stop":
        publish_and_exit(broker, TOPIC_STOP)
        print("stopped")

    elif cmd == "calibrate":
        if len(sys.argv) < 3:
            print("Usage: bush-valve calibrate <steps>")
            sys.exit(1)
        steps = int(sys.argv[2])
        publish_and_exit(broker, TOPIC_CALIBRATE, str(steps))
        print(f"open_steps -> {steps}")

    elif cmd == "status":
        payload = subscribe_one(broker, TOPIC_STATUS, timeout=3.0)
        if payload:
            try:
                data = json.loads(payload)
                print(json.dumps(data, indent=2))
            except ValueError:
                print(payload)
        else:
            print("No status received (valve offline?)")
            sys.exit(1)

    elif cmd == "watch":
        watch(broker, [TOPIC_STATUS, TOPIC_ACTUAL])

    else:
        print(f"Unknown command: {cmd}")
        print(__doc__.strip())
        sys.exit(1)


if __name__ == "__main__":
    main()

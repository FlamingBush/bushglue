def _int_list(s):
    try:
        return [int(x) for x in s.split(",") if x.strip() != ""]
    except ValueError:
        sys.exit(f"bad int list: {s!r}")


def _check_current(ma, allow_high):
    if not (0 <= ma <= CURRENT_HARD_MAX):
        sys.exit(f"{ma} mA outside 0..{CURRENT_HARD_MAX}")
    if ma > CURRENT_SOFT_MAX and not allow_high:
        sys.exit(f"{ma} mA > {CURRENT_SOFT_MAX} -- pass --allow-high-current if you mean it")


def _validate_grid(args):
    rpms = _int_list(args.rpm)
    args.rpms = [max(1, min(3000, v)) for v in rpms]
    accs = _int_list(args.acc)
    args.accs = [max(0, min(255, v)) for v in accs]
    if args.rpms != rpms or args.accs != accs:
        print("warning: rpm/acc values clamped (rpm 1..3000, acc 0..255)")
    args.currents = _int_list(args.current) if args.current else None
    if args.currents:
        for ma in args.currents + [args.restore_current]:
            _check_current(ma, args.allow_high_current)
    if not (0 <= args.a < args.b <= 1):
        sys.exit("need 0 <= a < b <= 1")
    if args.a < 0.05 or args.b > 0.95:
        print("warning: window close to a stop (a < 0.05 or b > 0.95)")
    if args.span < 100:
        sys.exit("span too small")
    args.repeats = max(1, args.repeats)


def _validate_stream(args):
    if args.dur <= 0 or args.rate < 1:
        sys.exit("need dur > 0 and rate >= 1")
    if args.wave == "square" and args.period <= 0:
        sys.exit("need period > 0")
    if args.span < 100:
        sys.exit("span too small")
    if args.max_rpm is not None and not (1 <= args.max_rpm <= 3000):
        sys.exit("max-rpm outside 1..3000")
    if args.current is not None:
        for ma in (args.current, args.restore_current):
            _check_current(ma, args.allow_high_current)


def parse_args():
    ap = argparse.ArgumentParser(prog="bush-valve-sweep", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--port", metavar="PATH", help="data CDC device (default: auto-detect)")
    ap.add_argument("--verbose", action="store_true", help="echo all serial traffic")
    sub = ap.add_subparsers(dest="cmd", required=True)

    sp = sub.add_parser("setup", description=SETUP_DOC,
                        formatter_class=argparse.RawDescriptionHelpFormatter,
                        help="interactive bench-window setup (valve that cannot seat-home)")
    sp.add_argument("--span", type=int, default=6400,
                    help="calibrate steps sent by `h` (default 6400)")

    gp = sub.add_parser("grid", description=GRID_DOC,
                        formatter_class=argparse.RawDescriptionHelpFormatter,
                        help="move_rpm x move_acc (x mA) move-quality sweep")
    gp.add_argument("--rpm", required=True, help="comma-separated move_rpm list")
    gp.add_argument("--acc", required=True, help="comma-separated move_acc list")
    gp.add_argument("--current", help="comma-separated maxtorque mA list")
    gp.add_argument("--a", type=float, default=0.25, help="low endpoint fraction (default 0.25)")
    gp.add_argument("--b", type=float, default=0.75, help="high endpoint fraction (default 0.75)")
    gp.add_argument("--span", type=int, default=6400, help="open_steps assumed for timeout math")
    gp.add_argument("--repeats", type=int, default=1, help="b/a round trips per cell")
    gp.add_argument("--settle", type=float, default=0.5, help="seconds between moves")
    gp.add_argument("--trace", type=int, metavar="MS",
                    help="firmware encoder trace interval (view with --verbose)")
    gp.add_argument("--csv", metavar="PATH", help="dump rows as CSV")
    gp.add_argument("--allow-high-current", action="store_true",
                    help=f"permit currents above {CURRENT_SOFT_MAX} mA")
    gp.add_argument("--restore-current", type=int, default=1000, metavar="MA",
                    help="maxtorque restored after a --current sweep (default 1000)")

    st = sub.add_parser("stream", description=STREAM_DOC,
                        formatter_class=argparse.RawDescriptionHelpFormatter,
                        help="stream a waveform, measure open-loop divergence")
    st.add_argument("--wave", required=True, choices=("sine", "square"))
    st.add_argument("--f0", type=float, default=0.2, help="chirp start Hz (sine)")
    st.add_argument("--f1", type=float, default=1.5, help="chirp end Hz (sine)")
    st.add_argument("--period", type=float, default=2.0, help="square period s")
    st.add_argument("--amp", type=float, default=0.2)
    st.add_argument("--center", type=float, default=0.5)
    st.add_argument("--dur", type=float, default=20.0, help="seconds")
    st.add_argument("--rate", type=int, default=30, help="samples/s")
    st.add_argument("--span", type=int, default=6400, help="open_steps for err_steps math")
    st.add_argument("--trace", type=int, default=50, metavar="MS",
                    help="firmware encoder trace interval (default 50)")
    st.add_argument("--csv", metavar="PATH", help="dump tracept divergence as CSV")
    st.add_argument("--max-rpm", type=int, metavar="RPM",
                    help="stream_max_rpm for this run (1-3000, restored after)")
    st.add_argument("--current", type=int, metavar="MA",
                    help="maxtorque for this run (restored after)")
    st.add_argument("--allow-high-current", action="store_true",
                    help=f"permit currents above {CURRENT_SOFT_MAX} mA")
    st.add_argument("--restore-current", type=int, default=1000, metavar="MA",
                    help="maxtorque restored after a --current run (default 1000)")

    args = ap.parse_args()
    if args.cmd == "grid":
        _validate_grid(args)
    elif args.cmd == "stream":
        _validate_stream(args)
    elif args.span < 100:
        sys.exit("span too small")
    return args


def main():
    args = parse_args()
    port = args.port or find_port()
    link = Link(port, args.verbose)
    cl = Cleanup(link)
    rc = 0
    try:
        {"setup": cmd_setup, "grid": cmd_grid, "stream": cmd_stream}[args.cmd](args, link, cl)
    except KeyboardInterrupt:
        print("\ninterrupted -- cleaning up")
        cl.stop_ok = True
        rc = 130
    except Abort as e:
        print(f"ABORT: {e}")
        cl.stop_ok = True
        rc = 2
    except Exception as e:
        print(f"ERROR: {type(e).__name__}: {e}")
        cl.stop_ok = True
        rc = 1
    finally:
        cl.run()
    sys.exit(rc)


if __name__ == "__main__":
    main()

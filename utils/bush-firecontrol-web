#!/usr/bin/env python3
"""
bush-firecontrol-web: touch-friendly web UI for phone-based flame control.
Serves on port 8080. Publishes to MQTT on button tap.
"""
import argparse
import json
import threading
import time
from http.server import BaseHTTPRequestHandler, HTTPServer
import paho.mqtt.client as mqtt

TOPIC_FLARE         = "bush/flame/flare/pulse"
TOPIC_BIGJET        = "bush/flame/bigjet/pulse"
TOPIC_POOF          = "bush/flame/poof/pulse"
TOPIC_PIPELINE_PING = "bush/pipeline/ping"
TOPIC_PIPELINE_PONG = "bush/pipeline/pong"

BIGJET_DURATIONS = [50, 100, 200, 300, 500, 800, 1000, 1500, 2000, 3000, 5000, 8000]
FLARE_DURATIONS  = [50, 100, 200, 300, 500, 800, 1000, 1500, 2000, 3000, 5000, 8000]
POOF_DURATIONS   = [20, 30, 50, 75, 100, 150, 200, 250, 300, 350, 400, 450]

_state = {"connected": False, "last": None}
_state_lock = threading.Lock()
_mqttc = None


def _fire(topic, ms):
    if _mqttc and _state["connected"]:
        _mqttc.publish(topic, str(ms), qos=0)
        with _state_lock:
            _state["last"] = {"topic": topic, "ms": ms, "t": time.time()}
        return True
    return False


def _fmt(ms):
    return f"{ms/1000:.1g}s" if ms >= 1000 else f"{ms}ms"


def _buttons(durations, topic, css_class):
    return "\n".join(
        f'<button class="btn {css_class}" '
        f'ontouchstart="fire(\'{topic}\',{ms})" '
        f'onclick="fire(\'{topic}\',{ms})">'
        f'{_fmt(ms)}</button>'
        for ms in durations
    )


HTML = """\
<!DOCTYPE html>
<html lang="en">
<head>
<meta name="viewport" content="width=device-width,initial-scale=1,user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<title>Fire Control</title>
<style>
*{{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}}
body{{background:#111;color:#fff;font-family:system-ui,sans-serif;
     height:100dvh;display:flex;flex-direction:column;overflow:hidden}}
#bar{{display:flex;justify-content:space-between;align-items:center;
     padding:6px 12px;background:#1a1a1a;border-bottom:1px solid #333;
     font-size:.85rem;flex-shrink:0}}
#bar h1{{font-size:1rem}}
#conn{{font-size:.8rem}}
#conn.ok{{color:#4f4}}
#conn.err{{color:#f44;animation:blink 1s step-start infinite}}
@keyframes blink{{50%{{opacity:0}}}}
#grid{{display:flex;flex:1;gap:6px;padding:6px;min-height:0}}
.col{{flex:1;display:flex;flex-direction:column;gap:5px}}
.col-hdr{{text-align:center;font-size:.85rem;font-weight:700;
         padding:5px 2px;border-radius:6px;flex-shrink:0}}
.bigjet .col-hdr{{background:#0d2d4a;color:#6cf}}
.flare  .col-hdr{{background:#3a0d00;color:#fa6}}
.poof   .col-hdr{{background:#0a3a1a;color:#6f6}}
.btn{{flex:1;border:none;border-radius:8px;font-size:1.1rem;font-weight:700;
     color:#fff;cursor:pointer;min-height:0;transition:filter .1s}}
.btn:active{{filter:brightness(2)}}
.bigjet .btn{{background:#1a4a80}}
.flare  .btn{{background:#80280a}}
.poof   .btn{{background:#1a6030}}
.btn.flash{{filter:brightness(2.5)}}
#log{{text-align:center;font-size:.75rem;padding:5px;
     background:#1a1a1a;color:#888;flex-shrink:0}}
</style>
</head>
<body>
<div id="bar">
  <h1>🔥 Fire Control</h1>
  <span id="conn" class="err">● disconnected</span>
</div>
<div id="grid">
  <div class="col bigjet">
    <div class="col-hdr">BIGJET</div>
    {bigjet}
  </div>
  <div class="col flare">
    <div class="col-hdr">FLARE</div>
    {flare}
  </div>
  <div class="col poof">
    <div class="col-hdr">POOF</div>
    {poof}
  </div>
</div>
<div id="log">tap a button to fire</div>
<script>
function fire(topic,ms){{
  const label=(topic.includes('flare')?'FLARE':topic.includes('poof')?'POOF':'BIGJET')+' '+fmtMs(ms);
  fetch('/fire',{{method:'POST',headers:{{'Content-Type':'application/json'}},
    body:JSON.stringify({{topic,ms}})}})
  .then(r=>r.json()).then(d=>{{
    document.getElementById('log').textContent=d.ok?'fired: '+label:'not connected';
  }}).catch(()=>document.getElementById('log').textContent='error');
}}
function fmtMs(ms){{return ms>=1000?(ms/1000).toFixed(ms%1000?1:0)+'s':ms+'ms'}}
function poll(){{
  fetch('/status').then(r=>r.json()).then(d=>{{
    const el=document.getElementById('conn');
    el.className=d.connected?'ok':'err';
    el.textContent=d.connected?'● connected':'● disconnected';
  }}).catch(()=>{{}});
  setTimeout(poll,3000);
}}
poll();
</script>
</body>
</html>
""".format(
    bigjet=_buttons(BIGJET_DURATIONS, TOPIC_BIGJET, "bigjet"),
    flare=_buttons(FLARE_DURATIONS,  TOPIC_FLARE,  "flare"),
    poof=_buttons(POOF_DURATIONS,    TOPIC_POOF,   "poof"),
)


class Handler(BaseHTTPRequestHandler):
    def log_message(self, fmt, *args):
        pass  # suppress access logs

    def _send(self, code, ctype, body):
        b = body if isinstance(body, bytes) else body.encode()
        self.send_response(code)
        self.send_header("Content-Type", ctype)
        self.send_header("Content-Length", len(b))
        self.end_headers()
        self.wfile.write(b)

    def do_GET(self):
        if self.path in ("/", "/index.html"):
            self._send(200, "text/html; charset=utf-8", HTML)
        elif self.path == "/status":
            with _state_lock:
                self._send(200, "application/json",
                           json.dumps({"connected": _state["connected"]}))
        else:
            self._send(404, "text/plain", "not found")

    def do_POST(self):
        if self.path == "/fire":
            length = int(self.headers.get("Content-Length", 0))
            try:
                data = json.loads(self.rfile.read(length))
                ok = _fire(data["topic"], int(data["ms"]))
                self._send(200, "application/json", json.dumps({"ok": ok}))
            except Exception as e:
                self._send(400, "application/json", json.dumps({"ok": False, "err": str(e)}))
        else:
            self._send(404, "text/plain", "not found")


def main():
    global _mqttc

    ap = argparse.ArgumentParser(description="Fire control web UI")
    ap.add_argument("--broker", default="localhost")
    ap.add_argument("--port",   type=int, default=1883)
    ap.add_argument("--web-port", type=int, default=8080)
    args = ap.parse_args()

    _mqttc = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)

    def on_connect(c, u, f, rc, p=None):
        with _state_lock:
            _state["connected"] = (str(rc) == "Success" or rc == 0)
        c.subscribe(TOPIC_PIPELINE_PING)

    def on_disconnect(c, u, f, rc, p=None, *a):
        with _state_lock:
            _state["connected"] = False

    def on_message(c, u, msg):
        if msg.topic == TOPIC_PIPELINE_PING:
            c.publish(TOPIC_PIPELINE_PONG, "")

    _mqttc.on_connect    = on_connect
    _mqttc.on_disconnect = on_disconnect
    _mqttc.on_message    = on_message

    def _mqtt_thread():
        try:
            _mqttc.connect(args.broker, args.port, keepalive=10)
        except Exception as e:
            print(f"[firecontrol-web] MQTT connect failed: {e}")
        _mqttc.loop_forever()

    threading.Thread(target=_mqtt_thread, daemon=True).start()

    server = HTTPServer(("0.0.0.0", args.web_port), Handler)
    print(f"[firecontrol-web] http://0.0.0.0:{args.web_port}/  broker={args.broker}:{args.port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass


if __name__ == "__main__":
    main()

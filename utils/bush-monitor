def _valve_field_publish(attr, value):
    """(topic, payload, retain) to publish for a live-edited valve field, or None
    for calibrate (which commits on Enter). Payload formats match bush-valve."""
    if attr == "valve_draft_target":
        return ("bush/fire/valve/target", f"{value:.3f}", False)
    if attr == "valve_draft_enabled":
        return ("bush/fire/valve/breath", json.dumps({"enabled": bool(value)}), False)
    if attr == "valve_draft_amp":
        return ("bush/fire/valve/breath", json.dumps({"amplitude": value}), False)
    if attr == "valve_draft_period_ms":
        return ("bush/fire/valve/breath", json.dumps({"period_ms": int(value)}), False)
    if attr == "valve_draft_skew":
        return ("bush/fire/valve/breath", json.dumps({"skew": value}), False)
    return None


def _parse_auto_payload(payload) -> "bool | None":
    """Tolerant on/off parser mirroring the bush-variable-valves service."""
    try:
        s = payload.decode(errors="ignore").strip().lower()
    except AttributeError:
        s = str(payload).strip().lower()
    if s in ("on", "true", "1", "yes"):
        return True
    if s in ("off", "false", "0", "no"):
        return False
    try:
        data = json.loads(s)
        if isinstance(data, dict) and "enabled" in data:
            return bool(data["enabled"])
    except (ValueError, TypeError):
        pass
    return None


def _spark_line(values, width: int, color: str) -> Text:
    """One-row Unicode block sparkline. `values` is an iterable of floats in
    [0, 1]; the latest `width` are rendered right-aligned."""
    vals = list(values)[-width:]
    t = Text()
    if not vals:
        t.append("·" * width, style="dim")
        return t
    # Left-pad with spaces so the trace ends at the right edge.
    pad = width - len(vals)
    if pad > 0:
        t.append(" " * pad)
    for v in vals:
        v = max(0.0, min(1.0, v))
        idx = int(round(v * 8))
        t.append(_SPARK[idx], style=color)
    return t


def build_valve_panel(s: State) -> Panel:
    state_color = _VALVE_STATE_COLOR.get(s.valve_state, "white")
    border = state_color if state_color not in ("dim",) else "dim"

    # Connection / availability
    if not s.valve_online:
        avail = Text("offline", style="bold red")
    elif s.valve_msg_ts and (time.time() - s.valve_msg_ts) > 5:
        avail = Text("stale", style="yellow")
    else:
        avail = Text("online", style=f"bold {state_color}")

    header = Text()
    header.append(f"{s.valve_state:<16}", style=f"bold {state_color}")
    header.append("  ")
    header.append(avail)
    header.append("   homed=", style="dim")
    header.append("yes" if s.valve_homed else "no",
                  style="green" if s.valve_homed else "red")
    header.append(f"   target={s.valve_target:.3f}", style="dim")
    header.append(f"   pos={s.valve_pos:.3f}",
                  style=f"bold {state_color}")
    if s.valve_last_error:
        header.append(f"   err={s.valve_last_error}", style="bold red")

    breath = Text()
    breath.append("breath  ", style="dim")
    breath.append("A=", style="dim")
    breath.append(f"{s.valve_breath_amp:.3f}")
    breath.append("  T=", style="dim")
    breath.append(f"{s.valve_breath_period_ms}ms")
    breath.append("  skew=", style="dim")
    breath.append(f"{s.valve_breath_skew:.2f}")
    breath.append("  ")
    breath.append("ON" if s.valve_breath_enabled else "OFF",
                  style="bold cyan" if s.valve_breath_enabled else "dim")

    # Sparkline width adapts to panel width; reserve some margin.
    spark = _spark_line(s.valve_pos_history, VALVE_HISTORY_LEN, "cyan")
    spark_label = Text("  ← 20 s position history", style="dim")

    # Position bar with target marker.
    bar_w = 40
    pos_filled = int(bar_w * max(0.0, min(1.0, s.valve_pos)))
    tgt_pos = int(bar_w * max(0.0, min(1.0, s.valve_target)))
    bar = Text()
    bar.append("[")
    for i in range(bar_w):
        if i == tgt_pos:
            bar.append("│", style="bold yellow")
        elif i < pos_filled:
            bar.append("█", style=state_color)
        else:
            bar.append("░", style="dim")
    bar.append("]")
    bar.append(f"  closed→open", style="dim")

    content = Text()
    content.append_text(header)
    content.append("\n")
    content.append_text(breath)
    content.append("\n")
    content.append_text(spark)
    content.append_text(spark_label)
    content.append("\n")
    content.append_text(bar)

    return Panel(content, title="[bold]NEEDLE VALVE[/bold]  [dim]bush/fire/valve/*[/dim]",
                 box=box.ROUNDED, border_style=border)


def build_valve_ctrl_panel(s: State) -> Panel:
    """Interactive valve drive + breath-tuning editor. The always-visible NEEDLE
    VALVE row above shows live state/pos/sparkline, so this shows only the editor."""
    state_color = _VALVE_STATE_COLOR.get(s.valve_state, "white")
    border = state_color if state_color != "dim" else "yellow"

    text = Text()
    for i, (attr, label, lo, hi, coarse, fine, kind) in enumerate(VALVE_FIELDS):
        sel = (i == s.valve_edit_field)
        text.append("► " if sel else "  ", style="bold yellow" if sel else "dim")
        text.append(f"{label:<11}", style="bold" if sel else "")
        val = getattr(s, attr)
        if kind == "bool":
            text.append("ON" if val else "OFF", style="bold cyan" if val else "dim")
        elif kind == "frac":
            text.append(f"{val:>6.3f}  ", style="bold" if sel else "")
            text.append_text(_bar(int(round(val * 100)), 100, 18,
                                  state_color if sel else "cyan"))
        else:  # int
            unit = "ms" if attr == "valve_draft_period_ms" else "steps"
            text.append(f"{int(val):>6d} {unit}", style="bold" if sel else "")
            if attr == "valve_draft_calib":
                if s.valve_draft_calib != s.valve_draft_calib_sent:
                    text.append("  * unsent — Enter to send", style="bold yellow")
                else:
                    text.append("  (volatile)", style="dim")
        text.append("\n")

    # Override caveat. Kept short so it never wraps at 80 cols, and placed
    # before the status line so the less-critical line clips first on a short
    # terminal. The always-visible NEEDLE VALVE panel still shows live state.
    if s.valve_auto_enabled:
        text.append("⚠ auto overwrites Position ~2×/s — [a] to pause for manual hold",
                    style="bold red")
    else:
        text.append("● manual control active (auto paused) — [a] to resume",
                    style="green")
    text.append("\n")
    text.append("Auto ", style="dim")
    text.append("ON" if s.valve_auto_enabled else "OFF",
                style="bold green" if s.valve_auto_enabled else "bold red")
    text.append("    Fine ", style="dim")
    text.append("on" if s.valve_fine else "off", style="cyan" if s.valve_fine else "dim")
    text.append("    homed ", style="dim")
    text.append("yes" if s.valve_homed else "no",
                style="green" if s.valve_homed else "red")

    # Key legend lives in the title (as the other modal panels do) so it never
    # clips when the editor body is squeezed on a short terminal.
    title = ("[bold]VALVE CONTROL[/bold]  [dim]←/→ adjust  jk move  "
             "\\[a]uto \\[h]ome \\[s]top \\[f]ine  Esc[/dim]")
    return Panel(text, title=title, box=box.ROUNDED, border_style=border)


def build_tts_panel(s: State) -> Panel:
    text = Text()
    if s.tts_text:
        style = "bold" if s.tts_speaking else _age_style(s.tts_ts)
        indicator = "[bold green]▶ SPEAKING[/bold green]" if s.tts_speaking else "[dim]last:[/dim]"
        text.append_text(Text.from_markup(indicator))
        text.append(f"  {s.tts_text}", style=f"{style} italic")
        text.append(f"   {_fmt_ts(s.tts_ts)}", style="dim")
    else:
        text.append("waiting for verse…", style="dim")
    text.append("\n")
    text.append("Clarity ", style="dim")
    text.append_text(_bar(s.tts_clarity, 100, BAR_WIDTH, "cyan"))
    text.append(f"  {s.tts_clarity:3d}%", style="cyan")
    border = "bold bright_green" if s.tts_speaking else "green"
    return Panel(text, title="[bold]TTS[/bold]  [dim]espeak-ng[/dim]",
                 box=box.ROUNDED, border_style=border)


def build_log_panel(s: State) -> Panel:
    # Audio device info + key hints embedded in the title
    in_dev  = _fmt_device(s.current_input)
    out_dev = _fmt_device(s.current_output)
    title = (f"[bold]Log[/bold]"
             f"  [dim]In:[/dim] [cyan]{in_dev}[/cyan]"
             f"  [dim]Out:[/dim] [green]{out_dev}[/green]"
             f"  [bold cyan]\\[i][/bold cyan][dim]nput[/dim]"
             f"  [bold green]\\[o][/bold green][dim]utput[/dim]"
             f"  [bold yellow]\\[t][/bold yellow][dim]ranscript[/dim]"
             f"  [bold red]\\[f][/bold red][dim]inalize[/dim]"
             f"  [bold cyan]\\[]/][/bold cyan][dim]clarity[/dim]"
             f"  [bold yellow]\\[v][/bold yellow][dim]alve[/dim]"
             f"  [bold white]\\[q][/bold white][dim]uit[/dim]")
    try:
        term_h = os.get_terminal_size().lines
    except OSError:
        term_h = 40
    _FIXED_ROWS = 1 + 5 + 4 + 14  # header + top + sentiment + bottom
    content_rows = max(1, term_h - _FIXED_ROWS - 2)  # -2 for panel border

    entries = list(s.log)[-content_rows:]  # newest at bottom
    text = Text()
    for ts, tag, msg in entries:
        tag_colour = {
            "TRANSCRIPT": "cyan",
            "T2V":        "bold yellow",
            "VERSE":      "yellow",
            "SENTIMENT":  "magenta",
            "FLARE":      "red",
            "BIGJET":     "dark_orange",
            "TTS":        "green",
            "TTS DONE":   "dim green",
        }.get(tag, "white")
        text.append(f"{_fmt_ts(ts)}  ", style="dim")
        text.append(f"{tag:<12}", style=f"bold {tag_colour}")
        text.append(f"{msg}\n", style="")
    return Panel(text, title=title, box=box.ROUNDED, border_style="dim")


def build_input_panel(s: State) -> Panel:
    text = Text()
    text.append(s.input_text, style="bold white")
    text.append("█", style="blink white")   # block cursor
    return Panel(text,
                 title="[bold yellow]Inject Transcript[/bold yellow]"
                       "  [dim]Enter=send  Esc=cancel[/dim]",
                 box=box.ROUNDED, border_style="yellow")


def _fmt_device(dev: dict | None) -> str:
    if dev is None:
        return "unknown"
    d = dev.get("device")
    if d is None:
        return "default"
    return str(d)


def build_audio_panel(s: State) -> Panel:
    """Device selector panel, used only in select_input / select_output modes."""
    if s.ui_mode == "select_input":
        devices = s.capture_devices
        title   = "[bold cyan]Select STT Input Device[/bold cyan]  [dim]Enter=confirm  Esc=cancel[/dim]"
        border  = "cyan"
    else:
        devices = s.playback_devices
        title   = "[bold green]Select TTS Output Device[/bold green]  [dim]Enter=confirm  Esc=cancel[/dim]"
        border  = "green"

    text = Text()
    if not devices:
        text.append("No devices found — is audio-agent running?", style="dim")
    else:
        for i, dev in enumerate(devices):
            cursor = "► " if i == s.selected_index else "  "
            style  = "bold reverse" if i == s.selected_index else ""
            text.append(cursor, style="bold yellow" if i == s.selected_index else "dim")
            text.append(f"[{dev['index']:2d}]  {dev['name']}", style=style)
            sr = dev.get('sr')
            ch = dev.get('channels')
            spec = f"  {int(sr)} Hz  {ch}ch" if sr and ch else f"  {dev.get('description', '')}"
            text.append(spec + "\n", style="dim" if i != s.selected_index else "dim reverse")
    return Panel(text, title=title, box=box.ROUNDED, border_style=border)


def build_header(s: State) -> Text:
    t = Text()
    status = "[bold green]● CONNECTED[/bold green]" if s.connected else "[bold red]● DISCONNECTED[/bold red]"
    t.append("Bush Glue Pipeline Monitor", style="bold white")
    t.append("   ")
    t.append_text(Text.from_markup(status))
    t.append(f"   broker {s.broker}:{MQTT_PORT}", style="dim")
    t.append(f"   {datetime.now().strftime('%H:%M:%S')}", style="dim")
    return t


def render(s: State) -> Layout:
    layout = Layout()

    layout.split_column(
        Layout(name="header",    size=1),
        Layout(name="top",       size=5),
        Layout(name="sentiment", size=4),
        Layout(name="valve",     size=6),
        Layout(name="bottom",    size=14),
        Layout(name="log"),
    )
    if s.ui_mode in ("select_input", "select_output"):
        layout["log"].update(build_audio_panel(s))
    elif s.ui_mode == "input_text":
        layout["log"].update(build_input_panel(s))
    elif s.ui_mode == "valve_ctrl":
        layout["log"].update(build_valve_ctrl_panel(s))
    else:
        layout["log"].update(build_log_panel(s))

    layout["top"].split_row(
        Layout(build_stt_panel(s),   name="stt"),
        Layout(build_verse_panel(s), name="verse"),
    )
    layout["sentiment"].update(build_sentiment_panel(s))
    layout["valve"].update(build_valve_panel(s))
    layout["bottom"].split_row(
        Layout(build_bush_panel(s), name="bush", ratio=2),
        Layout(build_tts_panel(s),  name="tts",  ratio=3),
    )
    layout["header"].update(build_header(s))
    return layout


# ── keyboard input ─────────────────────────────────────────────────────────
import select as _select


def _read_key(fd: int) -> str:
    """Read one keypress from an already-raw fd. Returns a string token."""
    ch = os.read(fd, 1).decode("utf-8", errors="ignore")
    if ch == "\x1b":
        r, _, _ = _select.select([fd], [], [], 0.05)
        if r:
            ch2 = os.read(fd, 1).decode("utf-8", errors="ignore")
            if ch2 == "[":
                r2, _, _ = _select.select([fd], [], [], 0.05)
                if r2:
                    ch3 = os.read(fd, 1).decode("utf-8", errors="ignore")
                    if ch3 == "A":
                        return "UP"
                    elif ch3 == "B":
                        return "DOWN"
                    elif ch3 == "C":
                        return "RIGHT"
                    elif ch3 == "D":
                        return "LEFT"
                    return f"ESC[{ch3}"
            return f"ESC{ch2}"
        return "ESC"
    return ch


def _handle_key(key: str):
    global _mqttc
    with state.lock:
        mode = state.ui_mode

    if mode == "normal":
        if key == "i":
            with state.lock:
                state.ui_mode = "select_input"
                state.selected_index = 0
            if _mqttc:
                _mqttc.publish("bush/audio/discover", "{}")
        elif key == "o":
            with state.lock:
                state.ui_mode = "select_output"
                state.selected_index = 0
            if _mqttc:
                _mqttc.publish("bush/audio/discover", "{}")
        elif key == "t":
            with state.lock:
                state.ui_mode = "input_text"
                state.input_text = ""
        elif key == "f":
            if _mqttc:
                _mqttc.publish("bush/pipeline/stt/force-finalize", "{}")
        elif key == "[":
            with state.lock:
                new_clarity = max(0, state.tts_clarity - 10)
                changed = new_clarity != state.tts_clarity
                state.tts_clarity = new_clarity
            if changed and _mqttc:
                _mqttc.publish("bush/audio/tts/set-clarity",
                               json.dumps({"clarity": new_clarity}))
        elif key == "]":
            with state.lock:
                new_clarity = min(100, state.tts_clarity + 10)
                changed = new_clarity != state.tts_clarity
                state.tts_clarity = new_clarity
            if changed and _mqttc:
                _mqttc.publish("bush/audio/tts/set-clarity",
                               json.dumps({"clarity": new_clarity}))
        elif key == "v":
            with state.lock:
                state.ui_mode = "valve_ctrl"
                state.valve_edit_field = 0
                # Seed the draft from current live values (calib has no live source).
                state.valve_draft_target = state.valve_target
                state.valve_draft_amp = state.valve_breath_amp
                state.valve_draft_period_ms = state.valve_breath_period_ms
                state.valve_draft_skew = state.valve_breath_skew
                state.valve_draft_enabled = state.valve_breath_enabled
        elif key in ("q", "Q", "\x03"):   # q or Ctrl-C
            with state.lock:
                state.quit = True

    elif mode == "input_text":
        if key == "ESC":
            with state.lock:
                state.ui_mode = "normal"
        elif key in ("\r", "\n"):   # Enter — send
            with state.lock:
                text = state.input_text.strip()
                state.ui_mode = "normal"
                state.input_text = ""
            if text and _mqttc:
                _mqttc.publish("bush/pipeline/stt/transcript",
                               json.dumps({"text": text, "ts": time.time()}))
        elif key in ("\x7f", "\x08"):   # Backspace / Delete
            with state.lock:
                state.input_text = state.input_text[:-1]
        elif len(key) == 1 and key.isprintable():
            with state.lock:
                state.input_text += key

    elif mode in ("select_input", "select_output"):
        with state.lock:
            if mode == "select_input":
                devices = state.capture_devices
            else:
                devices = state.playback_devices
            n = len(devices)

        if key in ("j", "DOWN") and n > 0:
            with state.lock:
                state.selected_index = (state.selected_index + 1) % n
        elif key in ("k", "UP") and n > 0:
            with state.lock:
                state.selected_index = (state.selected_index - 1) % n
        elif key.isdigit():
            with state.lock:
                idx = int(key)
                if 0 <= idx < n:
                    state.selected_index = idx
        elif key in ("\r", "\n"):    # Enter — confirm
            with state.lock:
                sel = state.selected_index
                if mode == "select_input":
                    devices = state.capture_devices
                    topic   = "bush/audio/stt/set-device"
                else:
                    devices = state.playback_devices
                    topic   = "bush/audio/tts/set-device"
                state.ui_mode = "normal"
            if _mqttc and devices and sel < len(devices):
                dev = devices[sel]
                # Use name for ALSA devices (hw:X), index for PA sources
                if dev.get("type") == "alsa":
                    payload = json.dumps({"device": dev["name"]})
                elif mode == "select_input":
                    payload = json.dumps({"device": dev["index"]})
                else:
                    payload = json.dumps({"device": dev["name"]})
                _mqttc.publish(topic, payload)
        elif key == "ESC":
            with state.lock:
                state.ui_mode = "normal"

    elif mode == "valve_ctrl":
        pub = None   # (topic, payload, retain) to publish after releasing the lock
        n = len(VALVE_FIELDS)
        if key == "ESC":
            with state.lock:
                state.ui_mode = "normal"
        elif key in ("j", "DOWN"):
            with state.lock:
                state.valve_edit_field = (state.valve_edit_field + 1) % n
        elif key in ("k", "UP"):
            with state.lock:
                state.valve_edit_field = (state.valve_edit_field - 1) % n
        elif key == "f":
            with state.lock:
                state.valve_fine = not state.valve_fine
        elif key == "a":
            with state.lock:
                new_auto = not state.valve_auto_enabled
                state.valve_auto_enabled = new_auto   # optimistic; the echo confirms
            pub = ("bush/fire/valve/auto", "on" if new_auto else "off", True)
        elif key == "h":
            pub = ("bush/fire/valve/home", "", False)
        elif key == "s":
            pub = ("bush/fire/valve/stop", "", False)
        elif key in ("LEFT", "RIGHT", " ", "\r", "\n"):
            with state.lock:
                attr, _label, lo, hi, coarse, fine, kind = VALVE_FIELDS[state.valve_edit_field]
                if key in ("\r", "\n"):
                    # Enter commits calibrate; no-op on other fields.
                    if attr == "valve_draft_calib":
                        state.valve_draft_calib_sent = state.valve_draft_calib
                        pub = ("bush/fire/valve/calibrate",
                               str(int(state.valve_draft_calib)), False)
                elif kind == "bool":
                    # LEFT/RIGHT/Space all toggle a boolean field.
                    new = not bool(getattr(state, attr))
                    setattr(state, attr, new)
                    pub = _valve_field_publish(attr, new)
                elif key in ("LEFT", "RIGHT"):
                    step = fine if state.valve_fine else coarse
                    direction = 1 if key == "RIGHT" else -1
                    new = max(lo, min(hi, getattr(state, attr) + direction * step))
                    new = int(round(new)) if kind == "int" else round(new, 4)
                    setattr(state, attr, new)
                    if attr != "valve_draft_calib":   # calib commits on Enter only
                        pub = _valve_field_publish(attr, new)
                # Space on a numeric field: no-op.
        if pub and _mqttc:
            _mqttc.publish(pub[0], pub[1], retain=pub[2])


def _keyboard_thread():
    """Daemon thread reading keypresses from stdin. Sets raw mode once for its lifetime."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setcbreak(fd)
        while True:
            key = _read_key(fd)
            _handle_key(key)
            with state.lock:
                if state.quit:
                    break
    except Exception:
        pass
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


# ── MQTT callbacks ─────────────────────────────────────────────────────────
def on_connect(client, userdata, flags, reason_code, properties):
    with state.lock:
        state.connected = (str(reason_code) == "Success")
    for topic in TOPICS:
        client.subscribe(topic)
    # Request fresh device list
    client.publish("bush/audio/discover", "{}")


def on_disconnect(client, userdata, flags, reason_code, properties):
    with state.lock:
        state.connected = False


def on_message(client, userdata, msg):
    topic = msg.topic
    now = time.time()
    try:
        with state.lock:
            state.last_msg_ts = now
            if topic == HEARTBEAT_TOPIC:
                return
            if topic == "bush/pipeline/stt/partial":
                data = json.loads(msg.payload)
                state.stt_partial = data.get("text", "")

            elif topic == "bush/pipeline/stt/transcript":
                data = json.loads(msg.payload)
                state.stt_text = data.get("text", "")
                state.stt_partial = ""
                state.stt_ts = now
                state.log.append((now, "TRANSCRIPT", f'"{state.stt_text[:80]}"'))

            elif topic == "bush/pipeline/t2v/processing":
                data = json.loads(msg.payload)
                state.t2v_query = data.get("text", "")
                state.t2v_processing = True
                state.log.append((now, "T2V", f'"{state.t2v_query[:80]}"'))

            elif topic == "bush/pipeline/t2v/verse":
                data = json.loads(msg.payload)
                state.verse_query = data.get("query", "")
                state.verse_text = data.get("text", "").replace("\n", " ")
                state.verse_ts = now
                state.t2v_processing = False
                state.log.append((now, "VERSE", f'"{state.verse_text[:80]}"'))

            elif topic == "bush/pipeline/sentiment/result":
                data = json.loads(msg.payload)
                state.scores = data.get("classification", [])
                state.sentiment_ts = now
                top = sorted(state.scores, key=lambda x: x["score"], reverse=True)
                if top:
                    label = top[0]["label"]
                    score = top[0]["score"]
                    flare = data.get("flare", 0)
                    bigjet = data.get("bigjet", 0)
                    state.log.append((now, "SENTIMENT",
                                      f"{label} {score:.2f}  flare={flare}ms  bigjet={bigjet}ms"))

            elif topic == "bush/flame/pulse":
                try:
                    data = json.loads(msg.payload.decode())
                    valve = data["valve"]
                    ms = int(data["ms"])
                    if valve == "flare":
                        state.flare_ms = ms
                        state.flare_ts = now
                        state.log.append((now, "FLARE", f"{ms} ms"))
                    elif valve == "bigjet":
                        state.bigjet_ms = ms
                        state.bigjet_ts = now
                        state.log.append((now, "BIGJET", f"{ms} ms"))
                    elif valve == "poof":
                        state.log.append((now, "POOF", f"{ms} ms"))
                except (ValueError, KeyError):
                    pass

            elif topic == "bush/pipeline/tts/speaking":
                data = json.loads(msg.payload)
                state.tts_text = data.get("text", "")
                state.tts_ts = now
                state.tts_speaking = True
                state.log.append((now, "TTS", f'"{state.tts_text[:80]}"'))

            elif topic == "bush/pipeline/tts/done":
                state.tts_speaking = False
                state.log.append((now, "TTS DONE", ""))

            elif topic == "bush/audio/devices":
                data = json.loads(msg.payload)
                state.capture_devices  = data.get("capture", [])
                state.playback_devices = data.get("playback", [])

            elif topic == "bush/audio/stt/device":
                state.current_input = json.loads(msg.payload)

            elif topic == "bush/audio/tts/device":
                state.current_output = json.loads(msg.payload)

            elif topic == "bush/audio/tts/clarity":
                data = json.loads(msg.payload)
                state.tts_clarity = int(data.get("clarity", 0))

            elif topic == "bush/fire/valve/actual":
                try:
                    state.valve_pos = float(msg.payload.decode())
                    state.valve_pos_history.append(state.valve_pos)
                    state.valve_msg_ts = now
                except (ValueError, AttributeError):
                    pass

            elif topic == "bush/fire/valve/status":
                try:
                    data = json.loads(msg.payload)
                    new_state = data.get("state", "?")
                    if new_state != state.valve_state:
                        state.log.append((now, "VALVE", f"{state.valve_state} -> {new_state}"))
                    state.valve_state = new_state
                    if "target" in data:
                        state.valve_target = float(data["target"])
                    state.valve_homed = bool(data.get("homed", False))
                    new_err = data.get("last_error")
                    if new_err and new_err != state.valve_last_error:
                        state.log.append((now, "VALVE ERR", str(new_err)))
                    state.valve_last_error = new_err
                    state.valve_msg_ts = now
                except (ValueError, KeyError):
                    pass

            elif topic == "bush/fire/valve/breath":
                try:
                    data = json.loads(msg.payload)
                    if "amplitude" in data:
                        state.valve_breath_amp = float(data["amplitude"])
                    if "period_ms" in data:
                        state.valve_breath_period_ms = int(data["period_ms"])
                    if "skew" in data:
                        state.valve_breath_skew = float(data["skew"])
                    if "enabled" in data:
                        state.valve_breath_enabled = bool(data["enabled"])
                except (ValueError, KeyError):
                    pass

            elif topic == "bush/fire/valve/online":
                state.valve_online = (msg.payload.decode(errors="ignore").strip() == "online")

            elif topic == "bush/fire/valve/auto":
                val = _parse_auto_payload(msg.payload)
                if val is not None:
                    if val != state.valve_auto_enabled:
                        state.log.append((now, "VALVE", f"auto {'on' if val else 'off'}"))
                    state.valve_auto_enabled = val

            elif topic == "bush/monitor/restart":
                state.log.append((now, "RESTART", "restarting monitor…"))
                os.execv(sys.executable, [sys.executable] + sys.argv)

    except Exception as e:
        with state.lock:
            state.log.append((now, "ERROR", str(e)))


# ── single-instance lock ────────────────────────────────────────────────────
_LOCK_PATH = Path("/tmp/bush-monitor.lock")
_lock_fh = None   # keep a reference so the lock isn't GC'd


def _acquire_lock() -> bool:
    """Return True if we got the lock (sole instance). False if another is running."""
    global _lock_fh
    _lock_fh = open(_LOCK_PATH, "w")
    try:
        fcntl.flock(_lock_fh, fcntl.LOCK_EX | fcntl.LOCK_NB)
        # Close-on-exec so os.execv (monitor restart) releases the lock
        fcntl.fcntl(_lock_fh, fcntl.F_SETFD, fcntl.FD_CLOEXEC)
        _lock_fh.write(str(os.getpid()))
        _lock_fh.flush()
        return True
    except OSError:
        return False


# ── main ───────────────────────────────────────────────────────────────────
def main():
    if not _acquire_lock():
        print("bush-monitor is already running — kill the existing instance first.", file=sys.stderr)
        sys.exit(1)

    global _mqttc
    broker = get_mqtt_broker()
    with state.lock:
        state.broker = broker

    mqttc = mqtt.Client(mqtt.CallbackAPIVersion.VERSION2)
    mqttc.on_connect = on_connect
    mqttc.on_disconnect = on_disconnect
    mqttc.on_message = on_message
    _mqttc = mqttc

    try:
        mqttc.connect(broker, MQTT_PORT, 60)
    except Exception as e:
        print(f"Cannot connect to MQTT broker at {broker}:{MQTT_PORT}: {e}", file=sys.stderr)
        sys.exit(1)

    # Watchdog: paho's receive thread can stall silently (TCP stays alive,
    # no on_disconnect, callbacks stop firing). Publish a heartbeat we also
    # subscribe to; if it doesn't echo back within HEARTBEAT_STALL_S, force
    # a reconnect.
    def _watchdog():
        while True:
            time.sleep(HEARTBEAT_PERIOD_S)
            try:
                mqttc.publish(HEARTBEAT_TOPIC, str(time.time()))
                with state.lock:
                    since = time.time() - state.last_msg_ts
                if since > HEARTBEAT_STALL_S:
                    with state.lock:
                        state.log.append((time.time(), "MQTT STALL",
                                          f"no echo for {int(since)}s — reconnecting"))
                        state.last_msg_ts = time.time()
                    try:
                        mqttc.reconnect()
                    except Exception as e:
                        with state.lock:
                            state.log.append((time.time(), "MQTT RECONNECT",
                                              f"failed: {e}"))
            except Exception:
                pass
    threading.Thread(target=_watchdog, daemon=True).start()

    mqttc.loop_start()

    # Start keyboard input thread (only if stdin is a tty)
    if sys.stdin.isatty():
        kb = threading.Thread(target=_keyboard_thread, daemon=True)
        kb.start()

    console = Console()
    try:
        with Live(render(state), console=console, refresh_per_second=8,
                  screen=True, vertical_overflow="visible") as live:
            while True:
                time.sleep(0.125)
                with state.lock:
                    should_quit = state.quit
                if should_quit:
                    break
                with state.lock:
                    live.update(render(state))
    except KeyboardInterrupt:
        pass
    finally:
        mqttc.loop_stop()
        mqttc.disconnect()


if __name__ == "__main__":
    main()

#!/bin/sh
# Called by udev when the TI PCM2912A USB codec appears.
# Mutes the mic sidetone to prevent speaker feedback.
# Volume levels are NOT restored here — amixer sset on this device causes
# usb_set_interface failures on the RK3568 OHCI controller.
sleep 0.5  # wait for ALSA mixer to be ready after enumeration
/usr/bin/amixer -c CODEC -q sset Mic playback mute > /dev/null 2>&1 || true

digraph bushglue {
    graph [
        rankdir=TD
        fontname="Helvetica"
        fontsize=12
        nodesep=0.6
        ranksep=0.8
        bgcolor="white"
    ]
    node [
        fontname="Helvetica"
        fontsize=11
        shape=box
        style="rounded,filled"
        fillcolor="#f5f5f5"
        color="#555555"
        margin="0.15,0.1"
    ]
    edge [
        fontname="Helvetica"
        fontsize=9
        color="#444444"
        labeldistance=2
    ]

    // IO
    MIC [label="Microphone\n(audio input)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    SPEAKER [label="Speaker\n(audio output)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    FLAME [label="Solenoids\n(propane output)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    BUTTONS [label="Buttons\n(physical input)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]
    FIRECONTROL [label="FireControl\n(website input)" shape=ellipse fillcolor="#d9ead3" color="#38761d"]

    // Services
    STT [label="bush-stt\nstt-service.py\n──────────────\nVosk STT\nmic input" fillcolor="#cfe2f3" color="#1155cc"]
    T2V [label="bush-t2v\nt2v-service.py\n──────────────\nRust HTTP :8765\nOllama embed\nChromaDB :8000" fillcolor="#cfe2f3" color="#1155cc"]
    TTS [label="bush-tts\ntts-service.py\n──────────────\nespeak-ng\nsox reverb" fillcolor="#cfe2f3" color="#1155cc"]
    SENTIMENT [label="bush-sentiment\nsentiment-service.py\n──────────────\nDistilBERT\nemotion classify\nfire orchestration" fillcolor="#cfe2f3" color="#1155cc"]
    AUDIOAGENT [label="audio-agent\naudio-agent.py\n──────────────\nPortAudio\ndevice discovery" fillcolor="#cfe2f3" color="#1155cc"]
    RELAYS [label="Relay Box" fillcolor="#cfe2f3" color="#1155cc"]

    // Layout hints
    { rank=source; MIC }
    { rank=same; STT; AUDIOAGENT }
    { rank=same; T2V }
    { rank=same; TTS; SENTIMENT }
    { rank=sink; SPEAKER; FLAME }
    //{ rank=same; FIRECONTROL; BUTTONS }

    // Audio I/O (no MQTT)
    MIC -> STT [color="#38761d"]
    TTS -> SPEAKER [color="#38761d"]

    // Main pipeline (MQTT)
    STT -> T2V [label="bush/pipeline/stt/transcript" color="#1155cc"]
    T2V -> TTS [label="bush/pipeline/t2v/verse" color="#1155cc"]
    T2V -> SENTIMENT [label="bush/pipeline/t2v/verse" color="#1155cc"]

    // TTS feedback
    TTS -> STT [label="bush/pipeline/tts/speaking\nbush/pipeline/tts/done" color="#cc4125" style=dashed]

    // TTS / sentiment
    TTS -> SENTIMENT [label="bush/pipeline/tts/done" color="#cc4125" style=dashed]

    // Flame effects
    SENTIMENT -> RELAYS [label="bush/flame/flare/pulse\nbush/flame/bigjet/pulse"]
    FIRECONTROL -> RELAYS [label="bush/flame/flare/pulse\nbush/flame/bigjet/pulse"]
    BUTTONS -> RELAYS [label="bush/flame/flare/pulse\nbush/flame/bigjet/pulse"]
    RELAYS -> FLAME [color="#38761d"]

    // Audio device management
    AUDIOAGENT -> STT [label="bush/audio/devices" color="#999999" style=dotted]
    AUDIOAGENT -> TTS [label="bush/audio/devices" color="#999999" style=dotted]
}

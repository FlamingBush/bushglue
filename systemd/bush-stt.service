[Unit]
Description=Speech-to-Text MQTT Publisher
After=network-online.target

[Service]
Type=simple
User=ubuntu
ExecStart=/usr/bin/python3 /mnt/c/Users/EB/bushglue/scripts/stt-service.py
Environment=PULSE_SERVER=unix:/mnt/wslg/PulseServer
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target

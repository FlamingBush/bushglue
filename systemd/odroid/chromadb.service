[Unit]
Description=ChromaDB Vector Database
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=odroid
ExecStart=/home/odroid/repos/bushglue/.venv/bin/chroma run --path /home/odroid/repos/bushglue/data/chromadb
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target

[Unit]
Description=text-to-verse with MQTT
After=chromadb.service ollama.service
Requires=chromadb.service ollama.service

[Service]
Type=simple
User=odroid
Environment=T2V_BIN=%h/repos/t2v/target/release/text-to-verse
Environment=AFFECTS_DIR=%h/repos/t2v/templates/affects
ExecStart=/usr/bin/python3 %h/repos/bushglue/t2v-service.py
MemoryMax=1500M
MemoryHigh=1200M
Restart=on-failure
RestartSec=30
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target

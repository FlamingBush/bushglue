[Unit]
Description=Text-to-Speech verse reader
After=network-online.target pulseaudio.service

[Service]
Type=simple
User=odroid
ExecStart=/usr/bin/python3 /home/odroid/repos/bushglue/tts-service.py
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target

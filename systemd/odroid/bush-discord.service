[Unit]
Description=Discord Bot for Bush Glue Pipeline (/pray command)
After=network-online.target mosquitto.service
Wants=network-online.target

[Service]
Type=simple
User=odroid
EnvironmentFile=%h/.config/bush/discord-token.env
ExecStart=/usr/bin/python3 %h/repos/bushglue/discord-bot.py
WorkingDirectory=%h/repos/bushglue/scripts
Restart=on-failure
RestartSec=10
TimeoutStartSec=60
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
